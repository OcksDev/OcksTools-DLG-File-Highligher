{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Dialog Script",
  "scopeName": "source.dlg",
  "fileTypes": ["dlg"],
  "patterns": [
    { "include": "#override-rand-tag" },
    { "include": "#override-with-at-tag" },
    { "include": "#override-seperator-tag" },
    { "include": "#angle-bracket-tag" },
    { "include": "#curly-bracket-tag" }
  ],
  "repository": {

    "angle-bracket-tag": {
      "comment": "Anything inside < >",
      "begin": "<",
      "end": ">",
      "name": "entity.other.attribute-name.dlg",
      "beginCaptures": {
        "0": { "name": "entity.name.tag.dlg" }
      },
      "endCaptures": {
        "0": { "name": "entity.name.tag.dlg" }
      },
      "patterns": [
        { "include": "#override-rand-tag" },
        { "include": "#equals-tag" },
        { "include": "#vars-tag" }
      ]
    },
    "override-with-at-tag": {
      "comment": "Anything inside @< >",
      "begin": "@<",
      "end": ">",
      "name": "entity.name.function.dlg",
      "beginCaptures": {
        "0": { "name": "entity.name.function.dlg" }
      },
      "endCaptures": {
        "0": { "name": "entity.name.function.dlg" }
      },
      "patterns": [
        { "include": "#override-rand-tag" },
        { "include": "#vars-tag" }
      ]
    },
    "override-rand-tag": {
      "comment": "Anything inside @[ ]",
      "match": "@\\[.*?\\]",
      "name": "entity.name.function.dlg"
    },
    "curly-bracket-tag": {
      "comment": "Anything inside { } immediately before <",
      "begin": "\\{(?=[^}]*\\}(?=<))",
      "end": "\\}(?=<)",
      "name": "constant.numeric.dlg",
      "beginCaptures": {
        "0": { "name": "constant.numeric.dlg" }
      },
      "endCaptures": {
        "0": { "name": "constant.numeric.dlg" }
      },
      "patterns": [
        { "include": "#vars-tag-curly" }
      ]
    },
    "override-seperator-tag": {
      "comment": "Deadass just this lol",
      "match": "</.*?>",
      "name": "constant.language.dlg"
    },

    "equals-tag": {
      "comment": "= or , inside <>",
      "match": "[=,](?=[^<>]*>)",
      "name": "entity.name.tag.dlg"
    },

    "vars-tag": {
      "comment": "vars inside <>",
      "match": "(?<=[=,<{])[!@#*~].*?(?=[=,>!}])",
      "name": "comment.line.dlg"
    },

    "vars-tag-curly": {
      "patterns": [
        {
          "comment": "LHS ! prefix var, only when == or != follows",
          "match": "(?<=[{,])!(?![!@#*~])\\w+(?=[!=])",
          "name": "comment.line.dlg"
        },
        {
          "comment": "RHS ! prefix var after comma",
          "match": "(?<=[,])!(?![!@#*~])\\w+",
          "name": "comment.line.dlg"
        },
        {
          "comment": "RHS value after == starting with a sigil",
          "match": "(?<===)[!@#*~]\\w+",
          "name": "comment.line.dlg"
        },
        {
          "comment": "LHS sigil chain starting with non-! sigil",
          "match": "(?<=[{,])[@#*~][!@#*~]*\\w+",
          "name": "comment.line.dlg"
        },
        {
          "comment": "LHS sigil chain after unconsumed leading !",
          "match": "(?<=[!])[!@#*~]+\\w+",
          "name": "comment.line.dlg"
        }
      ]
    }

  }
}
