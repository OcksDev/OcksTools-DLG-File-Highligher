{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Dialog Script",
  "scopeName": "source.dlg",
  "fileTypes": ["dlg"],
  "patterns": [
    { "include": "#override-with-at-tag" },
    { "include": "#override-seperator-tag" },
    { "include": "#angle-bracket-tag" },
    { "include": "#curly-bracket-tag" }
  ],
  "repository": {

    "angle-bracket-tag": {
      "comment": "Anything inside < >",
      "begin": "<",
      "end": ">",
      "name": "entity.other.attribute-name.dlg",
      "beginCaptures": {
        "0": { "name": "entity.name.tag.dlg" }
      },
      "endCaptures": {
        "0": { "name": "entity.name.tag.dlg" }
      },
      "patterns": [
        { "include": "#equals-tag" },
        { "include": "#vars-tag" }
      ]
    },

    "override-with-at-tag": {
      "comment": "Anything inside @< >",
      "match": "@<.*?>",
      "name": "entity.name.function.dlg"
    },
    "curly-bracket-tag": {
      "comment": "Anything inside { }",
      "begin": "\\{",
      "end": "\\}(?=<)",
      "name": "constant.numeric.dlg",
      "patterns": [
        { "include": "#vars-mod-tag" }
      ]
    },
    "override-seperator-tag": {
      "comment": "Deadass just this lol",
      "match": "</>",
      "name": "constant.language.dlg"
    },

    "equals-tag": {
      "comment": "= or , inside <>",
      "match": "[=,](?=[^<>]*>)",
      "name": "entity.name.tag.dlg"
    },

    "vars-tag": {
      "comment": "vars inside <>",
      "match": "[!@#*~](?=[^<>]*>)",
      "name": "comment.line.dlg"
    },

    "vars-mod-tag": {
      "comment": "vars inside <>",
      "match": "[!@#*~](?!=)(?=[^<>]*})",
      "name": "comment.line.dlg"
    }

  }
}
